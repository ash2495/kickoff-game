# Copy this file to .env for local development (Railway injects these as
# real env vars in production instead - Settings -> Variables on the service).

# MongoDB Atlas connection string (Database -> Connect -> Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/kickoffduel?retryWrites=true&w=majority

# Firebase console -> Authentication -> Sign-in method -> Google -> Web SDK
# configuration -> Web client ID. Used here to verify Google ID tokens
# server-side (the client doesn't need this value - google-services.json
# in android/app/ configures Google Sign-In on that side).
GOOGLE_WEB_CLIENT_ID=

# Any long random string - signs the profile auth token issued at login.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
